# Environment Variables — TEMPLATE ONLY
# Copy this file to .env and fill in your own values
# NEVER commit .env to GitHub

PORT=3001

# Google Maps / Places API
# Get from: https://console.cloud.google.com → Enable "Places API (New)"
GOOGLE_API_KEY=your_google_places_api_key_here

# Gemini AI
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# WhatsApp Business API (Meta Cloud API)
# Get from: https://developers.facebook.com → Your App → API Setup
WHATSAPP_TOKEN=your_meta_system_user_token_here
WHATSAPP_PHONE_ID=your_whatsapp_phone_number_id_here
WHATSAPP_VERIFY_TOKEN=choose_any_secret_string_here

# Demo override: All WhatsApp messages route to this number during testing
TEST_PROVIDER_PHONE=+92XXXXXXXXXX
